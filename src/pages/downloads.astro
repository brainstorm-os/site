---
import { type CollectionEntry, getCollection } from "astro:content";
import CornerMarks from "~/components/CornerMarks.astro";
import Footer from "~/components/Footer.astro";
import Header from "~/components/Header.astro";
import { PLATFORMS, Platform } from "~/content/releases";
import { SITE_NAME, links } from "~/content/site";
import Base from "~/layouts/Base.astro";

type Release = CollectionEntry<"releases">;

const published = (await getCollection("releases"))
	.filter((r) => r.data.status === "published")
	.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const latest = published[0];
const archive = published.slice(1);

const dateFmt = new Intl.DateTimeFormat("en", { year: "numeric", month: "short", day: "numeric" });

const assetsFor = (release: Release, platform: Platform) =>
	release.data.assets.filter((a) => a.platform === platform);

// Recognisable platform marks, inline SVG (the site bans raster + emoji glyphs).
const GLYPH: Record<Platform, string> = {
	[Platform.Mac]: `<svg viewBox="0 0 24 24" width="26" height="26" aria-hidden="true"><path fill="currentColor" d="M16.37 12.74c-.02-2.05 1.67-3.03 1.75-3.08-.95-1.4-2.43-1.59-2.96-1.61-1.26-.13-2.46.74-3.09.74-.64 0-1.62-.72-2.66-.7-1.38.02-2.65.8-3.36 2.03-1.43 2.48-.37 6.16 1.02 8.17.68.98 1.49 2.09 2.55 2.05 1.02-.04 1.4-.66 2.64-.66 1.23 0 1.58.66 2.66.64 1.1-.02 1.8-1 2.47-1.99.78-1.14 1.1-2.25 1.12-2.31-.02-.01-2.15-.83-2.17-3.28M14.4 6.07c.56-.68.94-1.62.84-2.57-.81.03-1.79.54-2.37 1.22-.52.6-.98 1.56-.86 2.48.9.07 1.83-.46 2.39-1.13"/></svg>`,
	[Platform.Windows]: `<svg viewBox="0 0 24 24" width="24" height="24" aria-hidden="true"><path fill="currentColor" d="M3 5.4 10.4 4.4v7H3zM11.4 4.26 21 3v8.4h-9.6zM3 12.6h7.4v7L3 18.6zM11.4 12.6H21V21l-9.6-1.3z"/></svg>`,
	[Platform.Linux]: `<svg viewBox="0 0 24 24" width="25" height="25" aria-hidden="true"><path fill="currentColor" d="M12 2c-1.96 0-3.3 1.6-3.3 3.7v2.9c0 .9-.45 1.5-1.05 2.4C6.7 12.3 5.7 13.6 5.7 15.5c0 .85.5 1.45 1.2 1.75-.2.55-.6 1.1-1.15 1.55-.4.32-.27.92.24 1.02.85.28 1.9.36 2.65-.02.45-.22.82-.58 1.1-.96.4.1.86.16 1.51.16.65 0 1.11-.06 1.51-.16.28.38.65.74 1.1.96.75.38 1.8.3 2.65.02.51-.1.64-.7.24-1.02-.55-.45-.95-1-1.15-1.55.7-.3 1.2-.9 1.2-1.75 0-1.9-1-3.2-1.95-4.5-.6-.9-1.05-1.5-1.05-2.4V5.7C15.3 3.6 13.96 2 12 2"/><ellipse cx="10.5" cy="6.6" rx=".75" ry="1" fill="var(--bg-edge)"/><ellipse cx="13.5" cy="6.6" rx=".75" ry="1" fill="var(--bg-edge)"/><path fill="#f5a623" d="M10.9 8.5h2.2l-1.1 1.3z"/></svg>`,
};

const title = "Downloads";
const description = `Download ${SITE_NAME} for macOS, Windows, and Linux. Every release is posted here.`;
---

<Base title={`${title} — ${SITE_NAME}`} description={description}>
	<CornerMarks />
	<Header />

	<main class="downloads-main">
		<div class="container">
			<header class="page-header">
				<p class="eyebrow">
					<span class="diamond" aria-hidden="true">◇</span>
					Downloads
				</p>
				<h1 class="page-title">Get {SITE_NAME}</h1>
				<p class="page-lede">
					A desktop app for macOS, Windows, and Linux. Free, forever — your data stays on your
					machine, and there's no account to sign up for.
				</p>
				{
					latest && (
						<p class="page-meta mono">
							<span>Latest · v{latest.data.version}</span>
							<span class="sep" aria-hidden="true">·</span>
							<time datetime={latest.data.date.toISOString()}>
								{dateFmt.format(latest.data.date)}
							</time>
							{latest.data.channel === "beta" && (
								<>
									<span class="sep" aria-hidden="true">·</span>
									<span class="channel">Beta</span>
								</>
							)}
						</p>
					)
				}
			</header>

			{
				latest ? (
					<section class="platforms" aria-label="Download by platform">
						{PLATFORMS.map((p) => {
							const assets = assetsFor(latest, p.id);
							return (
								<article class="platform-card" data-platform={p.id}>
									<div class="platform-head">
										<span class="platform-glyph" aria-hidden="true" set:html={GLYPH[p.id]} />
										<div>
											<h2 class="platform-name">{p.name}</h2>
											<p class="platform-req">{p.requirement}</p>
										</div>
									</div>
									{assets.length > 0 ? (
										<ul class="asset-list">
											{assets.map((a) => (
												<li>
													<a class="asset" href={a.href} download>
														<span class="asset-label">{a.label}</span>
														{a.size && <span class="asset-size mono">{a.size}</span>}
														<svg
															class="asset-arrow"
															width="14"
															height="14"
															viewBox="0 0 14 14"
															aria-hidden="true"
														>
															<path
																d="M7 2v8M3 7l4 4 4-4M2 12h10"
																fill="none"
																stroke="currentColor"
																stroke-width="1.5"
																stroke-linecap="round"
																stroke-linejoin="round"
															/>
														</svg>
													</a>
												</li>
											))}
										</ul>
									) : (
										<p class="asset-none mono">No build for this platform yet.</p>
									)}
								</article>
							);
						})}
					</section>
				) : (
					<section class="empty">
						<p class="empty-line">No public builds yet.</p>
						<p class="empty-sub">
							{SITE_NAME} builds are published on GitHub — check the releases page for the latest.
						</p>
						<a class="empty-cta" href={links.repo + "/releases"}>View releases</a>
					</section>
				)
			}

			{
				latest && (
					<section class="notes" aria-label="Release notes">
						{latest.data.highlights.length > 0 && (
							<ul class="highlights">
								{latest.data.highlights.map((h) => (
									<li>{h}</li>
								))}
							</ul>
						)}
						<p class="all-releases mono">
							<a href={links.repo + "/releases"} target="_blank" rel="noopener noreferrer">
								All releases on GitHub
							</a>
						</p>
					</section>
				)
			}

			{
				archive.length > 0 && (
					<section class="archive" aria-label="Previous releases">
						<h2 class="archive-title">Previous releases</h2>
						<ul class="archive-list">
							{archive.map((r) => (
								<li class="archive-item">
									<div class="archive-meta">
										<span class="archive-version">v{r.data.version}</span>
										<time class="archive-date mono" datetime={r.data.date.toISOString()}>
											{dateFmt.format(r.data.date)}
										</time>
										{r.data.channel === "beta" && <span class="archive-channel mono">Beta</span>}
									</div>
									<p class="archive-summary">{r.data.summary}</p>
									{r.data.assets.length > 0 && (
										<ul class="archive-assets">
											{r.data.assets.map((a) => (
												<li>
													<a href={a.href} download>
														{PLATFORMS.find((p) => p.id === a.platform)?.name} · {a.label}
													</a>
												</li>
											))}
										</ul>
									)}
								</li>
							))}
						</ul>
					</section>
				)
			}
		</div>

		<Footer />
	</main>
</Base>

<script>
	// Progressive enhancement: highlight the card for the visitor's OS. The page
	// renders all three platforms identically without JS — this only adds a hint.
	const ua = navigator.userAgent;
	const platform =
		/Mac|iPhone|iPad/.test(ua) && !/Windows/.test(ua)
			? "mac"
			: /Win/.test(ua)
				? "windows"
				: /Linux|X11/.test(ua)
					? "linux"
					: null;
	if (platform) {
		document.querySelector(`[data-platform="${platform}"]`)?.setAttribute("data-detected", "");
	}
</script>

<style>
	.downloads-main {
		display: flex;
		flex-direction: column;
		min-height: calc(100vh - 64px);
	}
	.container {
		padding-top: var(--space-9);
		padding-bottom: var(--space-9);
	}
	.page-header {
		display: flex;
		flex-direction: column;
		gap: var(--space-3);
		margin-bottom: var(--space-8);
		padding-bottom: var(--space-6);
		border-bottom: 1px solid var(--hairline);
		max-width: 60ch;
	}
	.eyebrow {
		display: inline-flex;
		align-items: center;
		gap: var(--space-2);
		color: var(--fog-1);
	}
	.diamond {
		color: var(--cyan-glow);
		font-size: 0.9em;
		line-height: 1;
	}
	.page-title {
		font-size: clamp(2rem, 3vw + 1rem, 3rem);
		font-weight: 500;
		letter-spacing: var(--tracking-hero);
		line-height: var(--leading-tight);
		color: var(--paper);
		text-wrap: balance;
	}
	.page-lede {
		font-size: var(--text-lg);
		line-height: var(--leading-snug);
		color: var(--fog-3);
		max-width: 56ch;
		text-wrap: balance;
	}
	.page-meta {
		display: inline-flex;
		align-items: center;
		gap: 10px;
		font-size: var(--text-mono);
		color: var(--fog-1);
		text-transform: uppercase;
		letter-spacing: var(--tracking-eyebrow);
		margin-top: var(--space-3);
		flex-wrap: wrap;
	}
	.page-meta .sep {
		color: var(--fog-1);
	}
	.channel {
		color: var(--cyan-bright);
	}

	.platforms {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: var(--space-4);
	}
	@media (max-width: 760px) {
		.platforms {
			grid-template-columns: 1fr;
		}
	}
	.platform-card {
		display: flex;
		flex-direction: column;
		gap: var(--space-4);
		padding: var(--space-5);
		border-radius: var(--radius-3);
		border: 1px solid var(--hairline-strong);
		background: var(--bg-edge);
		transition: border-color var(--dur-base) var(--ease-out);
	}
	.platform-card[data-detected] {
		border-color: var(--cyan-glow);
		box-shadow: 0 0 0 1px var(--cyan-glow);
	}
	.platform-head {
		display: flex;
		align-items: center;
		gap: var(--space-3);
	}
	.platform-glyph {
		display: inline-flex;
		color: var(--paper);
		flex-shrink: 0;
	}
	.platform-name {
		font-size: var(--text-lg);
		font-weight: 500;
		color: var(--paper);
		letter-spacing: var(--tracking-tight);
	}
	.platform-req {
		font-size: var(--text-xs);
		color: var(--fog-2);
		margin-top: 2px;
	}
	.asset-list {
		display: flex;
		flex-direction: column;
		gap: var(--space-2);
		margin-top: auto;
		list-style: none;
		padding: 0;
	}
	.asset {
		display: flex;
		align-items: center;
		gap: var(--space-3);
		padding: 11px 14px;
		border-radius: var(--radius-2);
		border: 1px solid var(--hairline-strong);
		color: var(--paper);
		background: transparent;
		transition:
			border-color var(--dur-base) var(--ease-out),
			background var(--dur-base) var(--ease-out),
			color var(--dur-base) var(--ease-out);
	}
	.asset:hover {
		border-color: var(--cyan-glow);
		color: var(--cyan-core);
		background: var(--hairline);
	}
	.asset-label {
		font-size: var(--text-sm);
		font-weight: 500;
		letter-spacing: var(--tracking-tight);
	}
	.asset-size {
		margin-left: auto;
		font-size: var(--text-mono);
		color: var(--fog-1);
		letter-spacing: var(--tracking-wide);
	}
	.asset-arrow {
		flex-shrink: 0;
		transition: transform var(--dur-base) var(--ease-out);
	}
	.asset:hover .asset-arrow {
		transform: translateY(2px);
	}
	.asset-none {
		font-size: var(--text-mono);
		color: var(--fog-1);
		text-transform: uppercase;
		letter-spacing: var(--tracking-eyebrow);
		margin-top: auto;
	}

	.notes {
		margin-top: var(--space-7);
		display: flex;
		flex-direction: column;
		gap: var(--space-4);
	}
	.highlights {
		display: flex;
		flex-direction: column;
		gap: 10px;
		max-width: 60ch;
		list-style: none;
		padding: 0;
	}
	.highlights li {
		position: relative;
		padding-left: var(--space-4);
		font-size: var(--text-base);
		line-height: var(--leading-snug);
		color: var(--fog-3);
	}
	.highlights li::before {
		content: "";
		position: absolute;
		left: 0;
		top: 0.6em;
		width: 5px;
		height: 5px;
		border-radius: 50%;
		background: var(--cyan-glow);
	}
	.all-releases a {
		font-size: var(--text-mono);
		text-transform: uppercase;
		letter-spacing: var(--tracking-eyebrow);
		color: var(--fog-2);
		transition: color var(--dur-base) var(--ease-out);
	}
	.all-releases a:hover {
		color: var(--cyan-core);
	}

	.empty {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: var(--space-4);
		padding: var(--space-7);
		border-radius: var(--radius-3);
		border: 1px solid var(--hairline-strong);
		background: var(--bg-edge);
		max-width: 60ch;
	}
	.empty-line {
		font-size: var(--text-xl);
		font-weight: 500;
		color: var(--paper);
		letter-spacing: var(--tracking-tight);
	}
	.empty-sub {
		font-size: var(--text-base);
		line-height: var(--leading-snug);
		color: var(--fog-3);
	}
	.empty-cta {
		display: inline-flex;
		align-items: center;
		padding: 11px 20px;
		border-radius: var(--radius-2);
		font-size: var(--text-sm);
		font-weight: 500;
		letter-spacing: var(--tracking-tight);
		color: #fff;
		background: var(--cyan-mid);
		box-shadow: 0 4px 14px rgba(225, 29, 72, 0.24);
		transition: background var(--dur-base) var(--ease-out);
	}
	.empty-cta:hover {
		background: var(--cyan-bright);
	}

	.archive {
		margin-top: var(--space-8);
		padding-top: var(--space-7);
		border-top: 1px solid var(--hairline);
	}
	.archive-title {
		font-size: var(--text-xl);
		font-weight: 500;
		color: var(--paper);
		letter-spacing: var(--tracking-tight);
		margin-bottom: var(--space-5);
	}
	.archive-list {
		display: flex;
		flex-direction: column;
		gap: var(--space-5);
		list-style: none;
		padding: 0;
	}
	.archive-item {
		display: flex;
		flex-direction: column;
		gap: var(--space-2);
		padding-bottom: var(--space-5);
		border-bottom: 1px solid var(--hairline);
	}
	.archive-item:last-child {
		border-bottom: none;
		padding-bottom: 0;
	}
	.archive-meta {
		display: inline-flex;
		align-items: baseline;
		gap: var(--space-3);
		flex-wrap: wrap;
	}
	.archive-version {
		font-size: var(--text-lg);
		font-weight: 500;
		color: var(--paper);
		letter-spacing: var(--tracking-tight);
	}
	.archive-date,
	.archive-channel {
		font-size: var(--text-mono);
		color: var(--fog-1);
		text-transform: uppercase;
		letter-spacing: var(--tracking-eyebrow);
	}
	.archive-channel {
		color: var(--cyan-bright);
	}
	.archive-summary {
		font-size: var(--text-base);
		line-height: var(--leading-snug);
		color: var(--fog-3);
		max-width: 60ch;
	}
	.archive-assets {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-2) var(--space-4);
		margin-top: var(--space-2);
		list-style: none;
		padding: 0;
	}
	.archive-assets a {
		font-size: var(--text-sm);
		color: var(--fog-2);
		transition: color var(--dur-base) var(--ease-out);
	}
	.archive-assets a:hover {
		color: var(--cyan-core);
	}
</style>
