</style>

<script>
	// Drive the hero's scroll reaction: a 0..1 progress over the first viewport
	// the crystal (CSS) and camera (3D) read to recede as you scroll.
	let ticking = false;
	const setDim = () => {
		const dim = Math.min(1, window.scrollY / Math.max(1, window.innerHeight * 0.9));
		document.documentElement.style.setProperty("--hero-dim", String(dim));
		ticking = false;
	};
	window.addEventListener(
		"scroll",
		() => {
			if (!ticking) {
				ticking = true;
				requestAnimationFrame(setDim);
			}
		},
		{ passive: true },
	);
	setDim();
</script>
