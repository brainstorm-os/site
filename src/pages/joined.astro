---
import BrandMark from "~/components/BrandMark.astro";
import { SITE_NAME } from "~/content/site";
import Base from "~/layouts/Base.astro";
---

<Base title={`${SITE_NAME} — you're on the list`} description="You're on the Brainstorm waitlist." noindex>
	<main class="page">
		<h1 class="brand">
			<BrandMark size={96} class="brand-mark" />
			<span class="wordmark">{SITE_NAME}</span>
		</h1>

		<p class="msg">You're on the list. We'll email you when it's ready.</p>
		<a class="back" href="/">Back</a>
	</main>
</Base>

<style>
	.page {
		min-height: 100vh;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: var(--space-5);
		padding: var(--space-6) var(--gutter-x);
		text-align: center;
	}
	.brand {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: var(--space-4);
		margin: 0;
		font-weight: 500;
	}
	.brand-mark {
		filter: drop-shadow(0 8px 28px rgba(var(--accent-rgb), 0.35));
	}
	.wordmark {
		font-size: clamp(1.5rem, 3vw + 0.5rem, 2.25rem);
		line-height: 1;
		color: var(--paper);
		letter-spacing: var(--tracking-tight);
	}
	.msg {
		font-size: var(--text-lg);
		color: var(--paper);
		letter-spacing: var(--tracking-tight);
	}
	.back {
		font-size: var(--text-sm);
		color: var(--fog-2);
		text-transform: uppercase;
		letter-spacing: var(--tracking-eyebrow);
	}
	.back:hover {
		color: var(--cyan-core);
	}
	.sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}
</style>
