---
import "~/styles/global.css";
import { SITE_NAME } from "~/content/site";
import { type Lang, alternatesFor, defaultLang, htmlLang, ogLocale } from "~/i18n/ui";

interface Props {
	title: string;
	description: string;
	canonical?: string;
	noindex?: boolean;
	lang?: Lang;
}

const { title, description, canonical, noindex, lang = defaultLang } = Astro.props;
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, Astro.site).toString();
// hreflang alternates so Google indexes each locale and serves the right one.
// Suppressed on noindex pages (e.g. /joined) — they shouldn't advertise pairs.
const alternates = Astro.site && !noindex ? alternatesFor(Astro.url.pathname, Astro.site) : [];
---

<!doctype html>
<html lang={htmlLang[lang]}>
	<head>
		<meta charset="utf-8" />
		<script is:inline>
			(() => {
				// Theme is shared across getbrainstorm.online subdomains via a cookie
				// so the docs open in whatever theme the site is in (and vice-versa).
				const m = document.cookie.match(/(?:^|; )bs-theme=(light|dark)/);
				const theme = m
					? m[1]
					: matchMedia("(prefers-color-scheme: dark)").matches
						? "dark"
						: "light";
				document.documentElement.dataset.theme = theme;
				document.documentElement.style.colorScheme = theme;
			})();
		</script>
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="theme-color" content="#f7f7f7" />
		<meta name="generator" content={Astro.generator} />
		<meta
			name="google-site-verification"
			content="NExj5Z6AMLGuszWb9UxsrZXdsO6WA2xXE-6JsnqLXq8"
		/>

		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalUrl} />
		{
			alternates.map((alt) => (
				<link rel="alternate" hreflang={alt.hreflang} href={alt.href} />
			))
		}

		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="mask-icon" href="/favicon.svg" color="#5b62e0" />

		<meta property="og:type" content="website" />
		<meta property="og:site_name" content={SITE_NAME} />
		<meta property="og:locale" content={ogLocale[lang]} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:image" content={new URL("/og.png", Astro.site).toString()} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta
			property="og:image:alt"
			content="Brainstorm — a desktop OS for you and your AI"
		/>
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={new URL("/og.png", Astro.site).toString()} />

		<meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow"} />
	</head>
	<body>
		<slot />

		<script>
			import { init } from "@amplitude/analytics-browser";

			if (!window.__amplitudeInitialized) {
				window.__amplitudeInitialized = true;
				init("cca1e2687dc8b1388f4b33372a97fdaa", {
					serverZone: "EU",
					autocapture: true,
				});
			}
		</script>
	</body>
</html>
