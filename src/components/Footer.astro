---
import BrandMark from "~/components/BrandMark.astro";
import NewsletterForm from "~/components/NewsletterForm.astro";
import { SITE_NAME, links } from "~/content/site";

const year = new Date().getFullYear();

// Root-absolute so they work from any page, not just the homepage.
const footerLinks = [
	{ label: "Overview", href: "/#overview" },
	{ label: "Apps", href: "/apps" },
	{ label: "Screenshots", href: "/#inside" },
	{ label: "How it works", href: "/#capabilities" },
	{ label: "Roadmap", href: "/#roadmap" },
];
---

<footer class="footer">
	<div class="container">
		<div class="footer-top">
			<div class="brand-col">
				<p class="brand">
					<BrandMark size={22} />
					<span class="wordmark">{SITE_NAME}</span>
				</p>
				<p class="positioning">
					A local-first, AI-native operating system for your knowledge work. Your data lives on
					your machine — no account required.
				</p>

				<div class="newsletter-col">
					<p class="newsletter-label">Get product updates</p>
					<NewsletterForm />
				</div>
			</div>

			<nav class="links" aria-label="Footer">
				{footerLinks.map((l) => <a href={l.href}>{l.label}</a>)}
				<a href={links.downloads}>Download</a>
				<a href={links.docs}>Docs</a>
				<a href={links.github} target="_blank" rel="noopener noreferrer">GitHub</a>
			</nav>
		</div>

		<div class="footer-meta">
			<p class="copyright mono">© {year} {SITE_NAME}</p>
			<a class="source mono" href={links.repo} target="_blank" rel="noopener noreferrer">
				Open source · AGPL-3.0
			</a>
		</div>

		<div class="footer-badges">
			<a href="https://openhunts.com" target="_blank" title="OpenHunts Club">
				<img alt="OpenHunts Club Member" height="105" src="https://cdn.openhunts.com/badges/club.webp" style="width: 195px; height: auto;" width="486">
			</a>
		</div>
	</div>
</footer>

<style>
	.footer {
		padding: var(--space-9) 0 var(--space-6);
		color: var(--fog-2);
		border-top: 1px solid var(--hairline);
		margin-top: var(--space-8);
	}
	.footer-top {
		display: flex;
		justify-content: space-between;
		gap: var(--space-7);
		flex-wrap: wrap;
		margin-bottom: var(--space-8);
	}
	.brand-col {
		display: flex;
		flex-direction: column;
		gap: var(--space-3);
		max-width: 42ch;
	}
	.brand {
		display: inline-flex;
		align-items: center;
		gap: 9px;
		font-size: var(--text-base);
		font-weight: 500;
		letter-spacing: var(--tracking-tight);
		color: var(--paper);
		margin: 0;
	}
	.positioning {
		font-size: var(--text-sm);
		line-height: var(--leading-snug);
		color: var(--fog-2);
		margin: 0;
	}
	.newsletter-col {
		display: flex;
		flex-direction: column;
		gap: var(--space-3);
		margin-top: var(--space-3);
	}
	.newsletter-label {
		font-size: var(--text-mono);
		color: var(--fog-1);
		letter-spacing: var(--tracking-eyebrow);
		text-transform: uppercase;
		margin: 0;
	}
	.links {
		display: grid;
		grid-auto-flow: column;
		grid-template-rows: repeat(4, auto);
		column-gap: var(--space-7);
		row-gap: 10px;
		justify-content: flex-start;
	}
	.links a {
		color: var(--fog-3);
		font-size: var(--text-sm);
		transition: color var(--dur-base) var(--ease-out);
	}
	.links a:hover {
		color: var(--cyan-core);
	}
	.footer-meta {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: var(--space-4);
		padding-top: var(--space-5);
		border-top: 1px solid var(--hairline);
		flex-wrap: wrap;
	}
	.copyright,
	.privacy,
	.source {
		font-size: var(--text-mono);
		color: var(--fog-1);
		letter-spacing: var(--tracking-eyebrow);
		text-transform: uppercase;
		margin: 0;
	}
	.source {
		transition: color var(--dur-base) var(--ease-out);
	}
	.source:hover {
		color: var(--cyan-core);
	}
	.footer-badges {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-4);
		align-items: center;
		margin-top: var(--space-5);
	}
</style>
