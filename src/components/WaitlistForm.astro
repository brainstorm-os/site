---
/**
 * The waitlist signup — a configured EmailSignupForm posting to /api/waitlist.
 * Keeps the `waitlist` class for the closer's page-level layout override.
 */
import EmailSignupForm from "~/components/EmailSignupForm.astro";

interface Props {
	/** A stable id so the label/input pair stays unique when rendered twice. */
	idSuffix?: string;
	cta?: string;
}
const { idSuffix = "hero", cta = "Join the waitlist" } = Astro.props;
---

<EmailSignupForm
	endpoint="/api/waitlist"
	trackEvent="Waitlist Signup"
	successLabel="You're on the list. We'll email you when it's ready."
	extraClass="waitlist"
	idSuffix={idSuffix}
	cta={cta}
/>
