---
import BrandMark from "~/components/BrandMark.astro";
import { SITE_NAME, links, nav } from "~/content/site";
---

<header class="site-header" data-header>
	<div class="container row">
		<div class="brand">
			<BrandMark size={24} />
			<span class="wordmark">{SITE_NAME}</span>
		</div>

		<nav class="primary" aria-label="Primary">
			{
				nav.map((item) => (
					<a href={item.href} class="nav-link" data-nav={item.section}>
						{item.label}
					</a>
				))
			}
			<span class="nav-underline" data-underline aria-hidden="true"></span>
		</nav>

		<div class="actions">
			<button
				class="theme-toggle"
				type="button"
				aria-label="Toggle color theme"
				title="Toggle theme"
				data-theme-toggle
			>
				<svg class="ico ico-moon" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
					<path
						d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"
						fill="none"
						stroke="currentColor"
						stroke-width="1.7"
						stroke-linejoin="round"></path>
				</svg>
				<svg class="ico ico-sun" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
					<circle cx="12" cy="12" r="4" fill="none" stroke="currentColor" stroke-width="1.7"
					></circle>
					<path
						d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"
						fill="none"
						stroke="currentColor"
						stroke-width="1.7"
						stroke-linecap="round"></path>
				</svg>
			</button>
			<a href={links.downloads} class="nav-docs">Download</a>
			<a href={links.docs} class="nav-docs">Docs</a>
			<a href="#waitlist" class="nav-cta">Join the waitlist</a>
		</div>
	</div>
</header>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: var(--z-fixed);
		padding: var(--space-3) 0;
		background: var(--header-bg);
		backdrop-filter: blur(6px) saturate(180%);
		-webkit-backdrop-filter: blur(6px) saturate(180%);
		border-bottom: 1px solid var(--hairline);
		transition:
			box-shadow var(--dur-base) var(--ease-out),
			background var(--dur-base) var(--ease-out);
	}
	.site-header[data-scrolled] {
		background: var(--header-bg-scrolled);
		box-shadow: 0 6px 24px rgba(0, 0, 0, 0.08);
	}
	.row {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: var(--space-5);
	}
	.brand {
		display: inline-flex;
		align-items: center;
		gap: 9px;
		color: var(--paper);
		font-weight: 500;
		letter-spacing: var(--tracking-tight);
		padding: 6px;
		flex-shrink: 0;
	}
	.wordmark {
		font-size: var(--text-base);
	}
	.primary {
		position: relative;
		display: flex;
		align-items: center;
		gap: 2px;
		font-size: var(--text-sm);
		margin-inline: auto;
	}
	.nav-link {
		color: var(--fog-2);
		padding: 7px 14px;
		border-radius: var(--radius-1);
		transition: color var(--dur-base) var(--ease-out);
		white-space: nowrap;
	}
	.nav-link:hover {
		color: var(--paper);
	}
	.nav-link[data-active] {
		color: var(--paper);
	}
	.nav-underline {
		position: absolute;
		bottom: -2px;
		left: 0;
		width: 0;
		height: 1.5px;
		border-radius: 1px;
		background: var(--cyan-glow);
		transform: translateX(0);
		opacity: 0;
		transition:
			transform var(--dur-slow) var(--ease-out),
			width var(--dur-slow) var(--ease-out),
			opacity var(--dur-base) var(--ease-out);
	}
	.nav-underline[data-on] {
		opacity: 1;
	}
	.actions {
		display: inline-flex;
		align-items: center;
		gap: var(--space-2);
		flex-shrink: 0;
	}
	.nav-docs {
		color: var(--fog-2);
		padding: 7px 14px;
		border-radius: var(--radius-1);
		font-size: var(--text-sm);
		white-space: nowrap;
		transition: color var(--dur-base) var(--ease-out);
	}
	.nav-docs:hover {
		color: var(--paper);
	}
	.theme-toggle {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 34px;
		height: 34px;
		border-radius: var(--radius-1);
		color: var(--fog-2);
		background: transparent;
		border: none;
		cursor: pointer;
		transition:
			color var(--dur-base) var(--ease-out),
			background var(--dur-base) var(--ease-out);
	}
	.theme-toggle:hover {
		color: var(--paper);
		background: var(--bg-edge);
	}
	.theme-toggle .ico-sun {
		display: none;
	}
	:global(:root[data-theme="dark"]) .theme-toggle .ico-sun {
		display: block;
	}
	:global(:root[data-theme="dark"]) .theme-toggle .ico-moon {
		display: none;
	}
	.nav-cta {
		flex-shrink: 0;
		display: inline-flex;
		align-items: center;
		padding: 8px 16px;
		border-radius: var(--radius-2);
		font-size: var(--text-sm);
		font-weight: 500;
		letter-spacing: var(--tracking-tight);
		color: #fff;
		border: 1px solid transparent;
		background: var(--cyan-mid);
		box-shadow: 0 4px 14px rgba(225, 29, 72, 0.24);
		transition:
			background var(--dur-base) var(--ease-out),
			box-shadow var(--dur-base) var(--ease-out);
	}
	.nav-cta:hover {
		background: var(--cyan-bright);
		box-shadow: 0 6px 18px rgba(225, 29, 72, 0.32);
	}
	@media (max-width: 760px) {
		.primary {
			display: none;
		}
	}
	/* Keep the wordmark on small screens — the brand needs a name, and with the
	   nav hidden there's room. Trim the CTA so both fit on narrow phones. */
	@media (max-width: 380px) {
		.nav-docs {
			display: none;
		}
		.nav-cta {
			padding: 8px 12px;
		}
		.row {
			gap: var(--space-3);
		}
	}
</style>

<script>
	const header = document.querySelector<HTMLElement>("[data-header]");
	const onScroll = () => {
		if (header) header.toggleAttribute("data-scrolled", window.scrollY > 8);
	};
	onScroll();
	window.addEventListener("scroll", onScroll, { passive: true });

	const links = [...document.querySelectorAll<HTMLAnchorElement>("[data-nav]")];
	const underline = document.querySelector<HTMLElement>("[data-underline]");
	const byId = new Map(links.map((l) => [l.dataset.nav, l]));

	const moveUnderlineTo = (link: HTMLElement | null) => {
		if (!underline) return;
		if (!link) {
			underline.removeAttribute("data-on");
			return;
		}
		// Underline the text, inset by the link's horizontal padding (14px).
		underline.style.width = `${Math.max(0, link.offsetWidth - 28)}px`;
		underline.style.transform = `translateX(${link.offsetLeft + 14}px)`;
		underline.setAttribute("data-on", "");
	};

	const setActive = (link: HTMLElement | null) => {
		for (const l of links) l.removeAttribute("data-active");
		link?.setAttribute("data-active", "");
		moveUnderlineTo(link);
	};

	const sections = links
		.map((l) => document.getElementById(l.dataset.nav ?? ""))
		.filter((el): el is HTMLElement => el !== null);

	if (sections.length) {
		const io = new IntersectionObserver(
			(entries) => {
				for (const entry of entries) {
					if (entry.isIntersecting) setActive(byId.get(entry.target.id) ?? null);
				}
			},
			{ rootMargin: "-30% 0px -60% 0px", threshold: 0 },
		);
		for (const s of sections) io.observe(s);
	}

	// Highlight the first section on load (before any scroll), once layout is
	// ready so the underline measures correctly.
	requestAnimationFrame(() => setActive(links[0] ?? null));

	// Re-measure the underline on resize so it stays aligned.
	window.addEventListener("resize", () => {
		const active = links.find((l) => l.hasAttribute("data-active")) ?? null;
		moveUnderlineTo(active);
	});
</script>

<script>
	const toggle = document.querySelector("[data-theme-toggle]");
	toggle?.addEventListener("click", () => {
		const root = document.documentElement;
		const next = root.dataset.theme === "dark" ? "light" : "dark";
		root.dataset.theme = next;
		root.style.colorScheme = next;
		// Shared across subdomains so the docs match.
		const dom = location.hostname.endsWith("getbrainstorm.online")
			? "; domain=.getbrainstorm.online"
			: "";
		document.cookie = `bs-theme=${next}; path=/; max-age=31536000; samesite=lax${dom}`;
	});
</script>
